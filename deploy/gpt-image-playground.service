[Unit]
Description=GPT Image Playground
After=network.target

[Service]
Type=simple
User=gpt-image-playground
WorkingDirectory=/opt/gpt-image-playground
Environment=NODE_ENV=production
Environment=HOSTNAME=127.0.0.1
Environment=PORT=3000
ExecStart=/usr/bin/env bun run start -- --hostname 127.0.0.1 --port 3000
Restart=always
RestartSec=5
TimeoutStartSec=300
TimeoutStopSec=30
KillSignal=SIGINT

[Install]
WantedBy=multi-user.target
